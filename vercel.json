{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/captacao.html" },
    { "source": "/captacao", "destination": "/captacao.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/cadastrar-senha", "destination": "/cadastrar-senha.html" },
    { "source": "/esqueci-senha", "destination": "/esqueci-senha.html" },
    { "source": "/redefinir-senha", "destination": "/redefinir-senha.html" },
    { "source": "/trilha", "destination": "/Index.html" },
    { "source": "/admin/trilhas", "destination": "/admin.html?tab=trilhas" },
    { "source": "/admin", "destination": "/admin-login.html" },
    { "source": "/admin-login", "destination": "/admin-login.html" },
    { "source": "/painel-admin", "destination": "/admin.html" },
    { "source": "/gestao", "destination": "/captacao-gestao.html" },
    { "source": "/api/cursos", "destination": "https://hasptpxcyavfdzxtwpws.supabase.co/functions/v1/trilhas-api/cursos" },
    { "source": "/api/cursos/:path*", "destination": "https://hasptpxcyavfdzxtwpws.supabase.co/functions/v1/trilhas-api/cursos/:path*" },
    { "source": "/api/trilhas", "destination": "https://hasptpxcyavfdzxtwpws.supabase.co/functions/v1/trilhas-api/trilhas" },
    { "source": "/api/trilhas/:path*", "destination": "https://hasptpxcyavfdzxtwpws.supabase.co/functions/v1/trilhas-api/trilhas/:path*" },
    { "source": "/api/aulas/:path*", "destination": "https://hasptpxcyavfdzxtwpws.supabase.co/functions/v1/trilhas-api/aulas/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*).(png|jpg|jpeg|gif|webp|svg|pdf|js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
